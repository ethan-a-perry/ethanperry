---
import Post from '../../layouts/Post.astro'

import { getCollection, render } from 'astro:content';
import { sortCollectionByMostRecent } from '../../wwwroot/js/utils';

export async function getStaticPaths() {
	const posts = sortCollectionByMostRecent(await getCollection('writing'));

	return posts.map((post, i) => ({
		params: { id: post.id },
		props: {
			post,
			previousPost: posts[i - 1],
			nextPost: posts[i + 1],
		},
	}));
}

const { post, previousPost, nextPost } = Astro.props;
const { Content } = await render(post);
---

<Post frontmatter={post.data} previousPost={previousPost} nextPost={nextPost}>
    <Content />
</Post>
