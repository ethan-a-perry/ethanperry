---
import Base from '../layouts/Base.astro';
import Link from "../components/Link.astro";
import Icon from "../components/Icon.astro";

import imgPortraitLagos from "/public/images/about/portrait-lagos.webp";
import imgPortraitTavira from "/public/images/about/portrait-tavira.webp";

const title = "About | Ethan Perry"
const description = "Some info about my background, experience, and interests."
---

<Base title={title} description={description}>
	<section class="flow-1">
		<h1>About</h1>
        <p>I'm 25 years old and currently living in my hometown in Colorado.</p>
	</section>

	<section class="margin-top-6">
		<h2>Experience</h2>
		<ul class="records margin-top-1">
			<li class="record">
				<span class="color-text-65 fs-s">2026</span>
				Construction and retail
			</li>
			<li class="record">
				<span class="color-text-65 fs-s">2024–2025</span>
				Traveled throughout Europe and Asia
			</li>
			<li class="record">
				<span class="color-text-65 fs-s">2023–2024</span>
				Software engineer at HPE
			</li>
			<li class="record">
				<span class="color-text-65 fs-s">2023</span>
				Data center technician at HPE
			</li>
			<li class="record">
				<span class="color-text-65 fs-s">2020–2021</span>
				Digital marketing, consulting, web deisgn, and account management
			</li>
			<li class="record">
				<span class="color-text-65 fs-s">2015–2020</span>
				Server and busser at a BBQ restaurant
			</li>
		</ul>
		<Link href="/resume_ethan_perry.pdf?v=2026-01" variant="underline">
			Download Resume
			<Icon name="open-in-new" size="16px"/>
		</Link>
	</section>

	<section class="margin-top-6">
		<h2>Current photos</h2>
		<div class="about--images margin-top-1 color-text-65 fs-s">
			<div>
				<img src={imgPortraitLagos.src} alt="ex1">
				<p>Tavira, Portugal (2024)</p>
			</div>

			<div>
				<img src={imgPortraitTavira.src} alt="ex2">
				<p>Tavira, Portugal (2024)</p>
			</div>
		</div>
	</section>
</Base>
